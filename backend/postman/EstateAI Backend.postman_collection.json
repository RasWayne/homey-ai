    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"propertyId\": \"{{propertyId}}\",\n  \"transactionType\": \"buy\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.id) { pm.environment.set('transactionId', json.id); }",
                  "if (json && json.currentMilestoneId) { pm.environment.set('milestoneId', json.currentMilestoneId); }",
                  "if (json && Array.isArray(json.milestones) && json.milestones.length > 0) {",
                  "  const firstMilestone = json.milestones[0];",
                  "  if (firstMilestone.id) pm.environment.set('milestoneId', firstMilestone.id);",
                  "  if (Array.isArray(firstMilestone.tasks) && firstMilestone.tasks.length > 0 && firstMilestone.tasks[0].id) {",
                  "    pm.environment.set('taskId', firstMilestone.tasks[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Import Transaction Milestone",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"propertyId\": \"{{propertyId}}\",\n  \"transactionType\": \"sell\",\n  \"currentMilestoneId\": \"{{milestoneId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/import-milestone",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "import-milestone"]
            }
          }
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}"]
            }
          }
        },
        {
          "name": "Update Current Milestone",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentMilestoneId\": \"{{milestoneId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}/current-milestone",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}", "current-milestone"]
            }
          }
        }
      ]
    },
