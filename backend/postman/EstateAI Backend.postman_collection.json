              "raw": "{\n  \"addressLine1\": \"123 Main St\",\n  \"city\": \"Miami\",\n  \"state\": \"FL\",\n  \"zipCode\": \"33101\",\n  \"listingUrl\": \"https://www.zillow.com/homedetails/example\",\n  \"listingPrice\": 550000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/properties",
              "host": ["{{baseUrl}}"],
              "path": ["properties"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.id) { pm.environment.set('propertyId', json.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Import Property From Listing",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingUrl\": \"https://www.zillow.com/homedetails/example\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/properties/import",
              "host": ["{{baseUrl}}"],
              "path": ["properties", "import"]
            }
          }
        },
        {
          "name": "Get Property",
          "request": {
            "method": "GET",
